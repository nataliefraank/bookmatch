# PostgreSQL (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookmatch
DB_USER=postgres
# Optional locally; Node connects over TCP (localhost), so set this if your role requires a password.
DB_PASSWD=
# Set to "true" only if your server requires SSL (e.g. some cloud hosts). Local Postgres usually omits this or sets false.
DB_SSL=false

# Session signing (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-secret-string

# Recommendations: default is Open Library subjects + search (no AI).
# Optional: Groq (OpenAI-compatible) first, then fallback to Open Library on error:
RECOMMENDATIONS_USE_GROQ=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
Server console: log prompt, raw JSON, and parsed titles (dev or set true):
GROQ_DEBUG_LOG=true